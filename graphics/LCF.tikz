\tikzset{
  compbox/.style={
    draw, rounded corners=5pt, align=center,
    text width=27mm, minimum height=8mm,
    font=\scriptsize, inner sep=1pt
  },
  highlight/.style={
    compbox,
    fill=green!20, draw=green!60!black, very thick
  }
}
% Þýtt út frá: https://setberg.hi.is/sites/setberg.hi.is/files/2024-09/louis_sextan_haefnirammar_-_yfirlit.pdf
\begin{tikzpicture}
  \matrix[matrix of nodes,
          nodes={compbox},
          column sep=2mm, row sep=2mm] {
    {Samfélagsvitund} &
    {Skapandi hugsun} &
    {Gagnrýnin hugsun} &
    {Siðferðilegur rökstuðningur} \\
    {Hnattrænt nám} &
    |[highlight]| {Upplýsingalæsi} &
    {Rannsókn og greining} &
    {Samþætt nám} \\
    {Þvermenningarlegt læsi, þekking \& hæfni} &
    {Grunnstoðir \mbox{símenntunar}} &
    {Munnleg samskipti} &
    |[highlight]| {Úrlausn vandamála} \\
    {Læsi á megindleg gögn} &
    {Lestur} &
    |[highlight]| {Teymisvinna} &
    {Skrifleg samskipti} \\
  };
